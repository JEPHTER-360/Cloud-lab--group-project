<svg width="960" height="320" xmlns="http://www.w3.org/2000/svg">
  <rect width="960" height="320" fill="#0a1628"/>

  <!-- Cloud shapes background -->
  <ellipse cx="160" cy="130" rx="100" ry="55" fill="rgba(37,99,235,0.12)"/>
  <ellipse cx="230" cy="108" rx="80" ry="50" fill="rgba(37,99,235,0.12)"/>
  <ellipse cx="760" cy="120" rx="110" ry="58" fill="rgba(37,99,235,0.1)"/>
  <ellipse cx="840" cy="98" rx="85" ry="50" fill="rgba(37,99,235,0.1)"/>
  <ellipse cx="500" cy="90" rx="130" ry="65" fill="rgba(37,99,235,0.08)"/>

  <!-- Server / database icons -->
  <rect x="380" y="70" width="90" height="130" rx="8" fill="rgba(37,99,235,0.22)" stroke="#2563eb" stroke-width="1.5"/>
  <rect x="394" y="84" width="62" height="10" rx="3" fill="#2563eb"/>
  <rect x="394" y="100" width="62" height="10" rx="3" fill="rgba(37,99,235,0.5)"/>
  <rect x="394" y="116" width="62" height="10" rx="3" fill="rgba(37,99,235,0.5)"/>
  <rect x="394" y="132" width="62" height="10" rx="3" fill="rgba(37,99,235,0.35)"/>
  <circle cx="420" cy="170" r="12" fill="rgba(96,165,250,0.2)" stroke="#60a5fa" stroke-width="1.5"/>

  <!-- Connection lines -->
  <line x1="420" y1="200" x2="300" y2="240" stroke="#2563eb" stroke-width="1" stroke-dasharray="4 3" opacity="0.5"/>
  <line x1="420" y1="200" x2="540" y2="240" stroke="#2563eb" stroke-width="1" stroke-dasharray="4 3" opacity="0.5"/>
  <line x1="420" y1="200" x2="420" y2="245" stroke="#2563eb" stroke-width="1" stroke-dasharray="4 3" opacity="0.5"/>

  <!-- Nodes -->
  <circle cx="300" cy="248" r="14" fill="rgba(37,99,235,0.3)" stroke="#60a5fa" stroke-width="1.5"/>
  <circle cx="420" cy="248" r="14" fill="rgba(37,99,235,0.3)" stroke="#60a5fa" stroke-width="1.5"/>
  <circle cx="540" cy="248" r="14" fill="rgba(37,99,235,0.3)" stroke="#60a5fa" stroke-width="1.5"/>

  <!-- Right server -->
  <rect x="490" y="80" width="80" height="110" rx="8" fill="rgba(37,99,235,0.15)" stroke="#1a3a6b" stroke-width="1"/>
  <rect x="502" y="93" width="56" height="8" rx="2" fill="rgba(37,99,235,0.4)"/>
  <rect x="502" y="106" width="56" height="8" rx="2" fill="rgba(37,99,235,0.3)"/>
  <rect x="502" y="119" width="56" height="8" rx="2" fill="rgba(37,99,235,0.3)"/>

  <!-- Text labels -->
  <text x="480" y="292" text-anchor="middle" fill="#60a5fa" font-family="system-ui,sans-serif" font-size="16" font-weight="700">Group 16 — Cloud Computing Practical Lab 1</text>
  <text x="480" y="312" text-anchor="middle" fill="#64748b" font-family="system-ui,sans-serif" font-size="11">Samuel · Jephter · Abdul · Kwabena · 2026</text>
</svg>
